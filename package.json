{
  "name": "pocket-desk-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "qa:smoke": "npm run build && node scripts/smoke-test.mjs",
    "release:check": "node scripts/release-check.mjs",
    "social:preview": "npm run build && node scripts/generate-social-preview.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "playwright": "^1.61.1"
  }
}
